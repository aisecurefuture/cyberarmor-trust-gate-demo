# CyberArmor URL Trust Gate demo — environment template.
#
# install.sh copies this to .env and replaces every "change-me*" value with a
# freshly generated random secret. You normally never edit this by hand.
#
# This is a DEMO configuration: insecure defaults are allowed and everything
# binds to localhost. Do NOT use these settings in production.

# --- Secrets (auto-randomized by install.sh) ---
CYBERARMOR_JWT_SECRET=change-me-jwt
POLICY_API_KEY=change-me-policy
TELEMETRY_API_KEY=change-me-telemetry

# --- Demo mode ---
CYBERARMOR_ALLOW_INSECURE_DEFAULTS=true
# TLS listener stays off for the demo — services speak plain HTTP internally.
CYBERARMOR_ENABLE_NATIVE_TLS_LISTENER=false

# --- Networking ---
# Bind published ports to localhost only by default. Set to 0.0.0.0 to expose
# the gate API on the host's network (e.g. to demo from another machine).
HOST_BIND=127.0.0.1

# --- Data stores ---
POSTGRES_USER=cyberarmor
POSTGRES_PASSWORD=cyberarmor
POSTGRES_DB=cyberarmor
DATABASE_URL=postgresql://cyberarmor:cyberarmor@postgres:5432/cyberarmor
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379
OPA_HOST_PORT=8181
POLICY_HOST_PORT=8001
AUDIT_HOST_PORT=8011

# --- Image tag ---
# Which published image tag to pull. Pin to a version for reproducible demos.
IMAGE_TAG=latest

# --- Optional reputation feeds (leave empty to skip) ---
SAFE_BROWSING_API_KEY=
VIRUSTOTAL_API_KEY=
